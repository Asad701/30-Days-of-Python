pipeline {
    agent any

    environment {
        IMAGE_NAME = "selenium-test"
        CONTAINER_NAME = "selenium-container"
    }

    stages {

        stage('Checkout Code') {
            steps {
                git branch: 'master', url: 'https://github.com/<yourusername>/selenium-webdriver.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh '''
                    docker build -t $IMAGE_NAME .
                    '''
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                script {
                    sh '''
                    docker run --name $CONTAINER_NAME --rm $IMAGE_NAME
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "✅ Selenium Test Passed!"
        }
        failure {
            echo "❌ Selenium Test Failed!"
        }
        always {
            sh '''
            docker system prune -af || true
            '''
        }
    }
}
