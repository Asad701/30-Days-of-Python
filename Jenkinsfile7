pipeline {
    agent any

    stages {
        stage('Build Docker Image') {
            steps {
                sh 'docker build -t selenium-test .'
            }
        }

        stage('Run Selenium Tests') {
            steps {
                sh 'docker run selenium-test'
            }
        }
    }

    post {
        always {
            sh 'docker system prune -af || true'
        }
        success {
            echo '✅ Selenium Test Passed!'
        }
        failure {
            echo '❌ Selenium Test Failed!'
        }
    }
}
